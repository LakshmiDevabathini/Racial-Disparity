                <component
                  refId="Package\Check IF File Exists\LoadRacialDisparityDetails\OLE DB Source"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="OLE DB Source"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select Race1
		, [Event ID]
		, cast ([Event Date] as date) EventDate
		---,member was discharged from: need to request from MhWIN
		, [Member ID]
		, [Consumer Last Name]
		, [Consumer First Name]
		, [Medicaid ID]
		, Population
		, Disposition
		, cast ([Request Date] as date) RequestDate
		, cast ([Service Date] as date) ServiceDate
		, [CRSP at Event]
		, [Event Category]
		,m.FullName as  MembersFullName
		,concat(ma.Address1
		,ma.city
		,ma.state 
		,ma.zip) as  FullAddress
		,ma.City
		,ma.state as State
		,ma.Zip
		,md.Gender 
		,m.DateOfBirth
	--	,md.race
		,mdd.PrimaryDesignationDesc as  PrimaryDiagnosis ----- disability designation
		,md.Language as PreferredLanguage
		,ma.CellPhone as  PrimaryPhoneNumber
		,ma.HomePhone as AlternatePhoneNumber
		--,Member Guardian status
	,CG_PFNAME  as  GuardianFirstName
	,cg_plname as GuardianLastName
	,CG_PRELAT as Guardianrelationship
	,concat(cg_paddr1,cg_pcity,cg_pzip) as   GuardianFullAddress
	,cg_pcity as Guardiancity
	,cg_pzip as Guardianzip
	,CG_PHPHONE as  GuardianPhoneNumber
		--,Guardian alternate number

--into work.dbo.LDRacialDisparityDetails
from [Work].[dbo].[LD_PI Event Report] P 
	left join warehouse.live.Member M on P.[Member ID] = M.MemberID
	left join warehouse.Live.MemberDemographics MD on M.MemberDemographicsID = MD.MemberDemographicsID
	left join warehouse.live.MemberAddress ma on m.MemberAddressID = ma.MemberAddressID
	left join warehouse.live.[MemberDisabilityDesignation] mdd 
	on m.MemberDisabilityDesignationID = mdd.MemberDisabilityDesignationID
	left join DATADWC.dbo.dwccgrpf grd on m.SourceGuardian_DWCCGRPF_CG_RCDID = grd.CG_RCDID
where Race1 in ('White', 'Black or African American')</property>
