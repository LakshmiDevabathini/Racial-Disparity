            <pipeline
              version="1">
              <components>
                <component
                  refId="Package\Check IF File Exists\By race\By Race"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="By Race"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select	Race1 as Race
		, sum(TotalEvents - OmittedExcludedEvents) as IncludedEvents
		, sum(CompliantEvents) as CompliantEvents
		, sum(case when Population = 'Adult' then TotalEvents - OmittedExcludedEvents else 0 end) as AdultIncludedEvents
		, sum(case when Population = 'Adult' then CompliantEvents else 0 end) as AdultCompliantEvents
		, sum(case when Population = 'Child' then TotalEvents - OmittedExcludedEvents else 0 end) as ChildIncludedEvents
		, sum(case when Population = 'Child' then CompliantEvents else 0 end) as ChildCompliantEvents
, sum(NonCompliantServiceCount) as NonCompliantServiceCount
from work.dbo.ldRaciaDisparityAggr
group by Race1 
order by Race1</property>
