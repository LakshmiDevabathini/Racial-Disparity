                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select	[CRSP at Event] as CRSPAtEvent, Population, Race1
		, count(*) as TotalEvents
		, count(case when Disposition = 'In-Compliance' then 1 else null end) as CompliantEvents
		, count(case when Disposition = 'Out-of-compliance' then 1 else null end) as NonCompliantEvents
		, count(case when Disposition = 'Omission/Excluded' then 1 else null end) as OmittedExcludedEvents
		, count(case when Disposition = 'Exception' then 1 else null end) as ExceptionEvents
, count(case when Disposition in ( 'Exception' , 'Out-of-compliance') 
					and [Service Date] is not null then 1 else null end) as NonCompliantServiceCount
---into work.dbo.ldRaciaDisparityAggr
from work.[dbo].[LD_PI Event Report] P left join warehouse.live.Member M on P.[Member ID] = M.MemberID
		left join warehouse.Live.MemberDemographics MD on M.MemberDemographicsID = MD.MemberDemographicsID
where Race1 in ('Black or African American', 'White')
group by [CRSP at Event], Population,  Race1
order by [CRSP at Event], Population, Race1</property>
