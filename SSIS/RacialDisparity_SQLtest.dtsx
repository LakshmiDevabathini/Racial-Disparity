                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].ExternalColumns[IncludedEvents]"
                          lineageId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].Columns[IncludedEvents]"
                          name="IncludedEvents"
                          truncationRowDisposition="FailComponent" />
                        <outputColumn
                          refId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].Columns[CompliantEvents]"
                          dataType="i4"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].ExternalColumns[CompliantEvents]"
                          lineageId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].Columns[CompliantEvents]"
                          name="CompliantEvents"
                          truncationRowDisposition="FailComponent" />
                        <outputColumn
                          refId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].Columns[AdultIncludedEvents]"
                          dataType="i4"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].ExternalColumns[AdultIncludedEvents]"
                          lineageId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].Columns[AdultIncludedEvents]"
                          name="AdultIncludedEvents"
                          truncationRowDisposition="FailComponent" />
                        <outputColumn
                          refId="Package\Check IF File Exists\By CRSP\By Race.Outputs[OLE DB Source Output].Columns[AdultCompliantEvents]"
                          dataType="i4"
                          errorOrTruncationOperation="Conversion"
