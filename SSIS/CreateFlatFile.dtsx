                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select	Race1 as Race
		, sum(TotalEvents - OmittedExcludedEvents) as IncludedEvents
		, sum(CompliantEvents) as CompliantEvents
		, sum(case when Population = 'Adult' then TotalEvents - OmittedExcludedEvents else 0 end) as AdultIncludedEvents
		, sum(case when Population = 'Adult' then CompliantEvents else 0 end) as AdultCompliantEvents
		, sum(case when Population = 'Child' then TotalEvents - OmittedExcludedEvents else 0 end) as ChildIncludedEvents
		, sum(case when Population = 'Child' then CompliantEvents else 0 end) as ChildCompliantEvents
, sum(NonCompliantServiceCount) as NonCompliantServiceCount
from work.dbo.ldRaciaDisparityAggr
group by Race1 
order by Race1</property>
